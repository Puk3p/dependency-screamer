<idea-plugin>
    <id>com.dependencyscreamer</id>
    <name>Dependency Screamer</name>
    <vendor>dependency-screamer</vendor>
    <description><![CDATA[
        Checks local pom.xml dependencies against Nexus Repository and warns when newer versions are available.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService
                serviceImplementation="com.nexusversionguard.infrastructure.settings.NexusGuardSettings"/>

        <applicationService
                serviceImplementation="com.nexusversionguard.application.service.DependencyAnalysisServiceProvider"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.nexusversionguard.ui.settings.NexusGuardConfigurable"
                id="com.nexusversionguard.settings"
                displayName="Dependency Screamer"/>

        <localInspection
                language="XML"
                groupName="Dependency Screamer"
                displayName="Outdated Maven dependency"
                shortName="NexusOutdatedDependency"
                level="WARNING"
                enabledByDefault="true"
                implementationClass="com.nexusversionguard.ui.inspection.OutdatedDependencyInspection"/>

        <annotator
                language="XML"
                implementationClass="com.nexusversionguard.ui.annotator.DependencyVersionAnnotator"/>

        <notificationGroup
                id="Dependency Screamer"
                displayType="BALLOON"/>

        <toolWindow
                id="Dependency Screamer"
                anchor="bottom"
                secondary="false"
                icon="/icons/logo.svg"
                factoryClass="com.nexusversionguard.ui.toolwindow.DependencyScreamerToolWindowFactory"/>

        <postStartupActivity
                implementation="com.nexusversionguard.ui.startup.NexusGuardStartupActivity"/>
    </extensions>
</idea-plugin>
