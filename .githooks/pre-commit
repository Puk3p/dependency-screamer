#!/bin/sh
#
# Pre-commit hook: runs basic checks before allowing a commit.
#

set -e

echo "🔍 [pre-commit] Running checks..."

# 1. No TODO/FIXME in staged files (warning only)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$STAGED_FILES" ]; then
    TODO_COUNT=$(echo "$STAGED_FILES" | xargs grep -rn "TODO\|FIXME\|HACK\|XXX" 2>/dev/null | wc -l | tr -d ' ')
    if [ "$TODO_COUNT" -gt 0 ]; then
        echo "⚠️  Warning: Found $TODO_COUNT TODO/FIXME/HACK/XXX markers in staged files."
    fi
fi

# 2. No merge conflict markers
if [ -n "$STAGED_FILES" ]; then
    CONFLICT=$(echo "$STAGED_FILES" | xargs grep -rn "^<<<<<<< \|^=======$\|^>>>>>>> " 2>/dev/null || true)
    if [ -n "$CONFLICT" ]; then
        echo "❌ Merge conflict markers found:"
        echo "$CONFLICT"
        exit 1
    fi
fi

# 3. No hardcoded secrets patterns
if [ -n "$STAGED_FILES" ]; then
    SECRETS=$(echo "$STAGED_FILES" | xargs grep -rEn "(password|secret|api_key|apikey|token)\s*=\s*[\"'][^\"']+[\"']" 2>/dev/null | grep -v "test" | grep -v ".example" || true)
    if [ -n "$SECRETS" ]; then
        echo "❌ Possible hardcoded secrets detected:"
        echo "$SECRETS"
        exit 1
    fi
fi

# 4. Check Kotlin files compile (if gradlew exists and kotlin files are staged)
KOTLIN_FILES=$(echo "$STAGED_FILES" | grep "\.kt$" || true)
if [ -n "$KOTLIN_FILES" ] && [ -f "./gradlew" ]; then
    echo "🔨 Compiling Kotlin..."
    ./gradlew compileKotlin --quiet 2>/dev/null || {
        echo "❌ Kotlin compilation failed. Fix errors before committing."
        exit 1
    }
fi

echo "✅ [pre-commit] All checks passed."
