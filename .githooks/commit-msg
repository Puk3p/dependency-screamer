#!/bin/sh
#
# Commit message hook: enforces Conventional Commits format.
#
# Format: <type>(<scope>): <description>
# Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build
#

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

PATTERN="^(feat|fix|docs|style|refactor|test|chore|ci|perf|build)(\(.+\))?: .{1,}"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo "❌ Invalid commit message format."
    echo ""
    echo "Expected: <type>(<scope>): <description>"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, ci, perf, build"
    echo ""
    echo "Examples:"
    echo "  feat(parser): add Maven property resolution"
    echo "  fix(client): handle Nexus timeout gracefully"
    echo "  chore: update dependencies"
    echo ""
    exit 1
fi
